<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/styles/main.css">
</head>
<%- include('nav.ejs')%>

<body class="grey-bg">
    <form class="form-box">
        <h4>글 작성</h4>
        <input value="<%=post.title%>" class="write-title" name="title" type="text" placeholder="제목을 입력해주세요">
        <textarea class="write-content" name="content" type="text" placeholder="내용을 입력해주세요"><%=post.content%></textarea>
        <button id="submit-btn">전송</button>
    </form>

<script>
    document.querySelector('.form-box').addEventListener('submit', (e)=>{
        e.preventDefault();
    })

    document.querySelector('#submit-btn').addEventListener('click', async () => {
        const title = document.querySelector('.write-title').value;
        const content = document.querySelector('.write-content').value;
        
        try {
            const response = await fetch('/edit', {method : 'PATCH', headers: {'Content-Type': 'application/json'},
                body : JSON.stringify({
                        _id : '<%=post._id%>',
                        title : title,
                        content : content
                })})
            const result = await response.json();

            if (response.ok) {
                alert(result.message)
                console.log(response)
                window.location.href = '/detail/<%=post._id%>';
            } else {
                alert (result.message)
            }

        } catch (error) {
            
        }
    })

    

</script>

</body>
</html>
